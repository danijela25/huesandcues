[connection signal="pressed" from="MainMargin/VBox/ButtonsHBox/ReadyButton" to="." method="_on_ready_button_pressed"]
[connection signal="pressed" from="MainMargin/VBox/ButtonsHBox/StartButton" to="." method="_on_start_button_pressed"]