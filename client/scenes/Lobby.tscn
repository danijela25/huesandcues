[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/Lobby.gd" id="1"]

[node name="Lobby" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="MainMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 40.0
offset_top = 40.0
offset_right = -40.0
offset_bottom = -40.0

[node name="VBox" type="VBoxContainer" parent="MainMargin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="TitleLabel" type="Label" parent="MainMargin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Lobby"

[node name="PlayerNameLabel" type="Label" parent="MainMargin/VBox"]
layout_mode = 2
text = "Ti si:"

[node name="RoomCodeLabel" type="Label" parent="MainMargin/VBox"]
layout_mode = 2
text = "Kod sobe:"

[node name="HostLabel" type="Label" parent="MainMargin/VBox"]
layout_mode = 2
text = "Host:"

[node name="PlayersTitle" type="Label" parent="MainMargin/VBox"]
layout_mode = 2
text = "Igrači:"

[node name="PlayersContainer" type="VBoxContainer" parent="MainMargin/VBox"]
layout_mode = 2
